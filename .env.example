# Chronos Ponto - Environment Variables

# Supabase Configuration
# The Supabase URL and Key are required for the database connection and auth.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database URL (Connection string for Prisma - typically PGBouncer/Direct for Supabase PG)
# Example: postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"

# Gemini API Key for intelligent parsing
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# App Configuration
NODE_ENV="development"
PORT=3000
